    std::string_view enum_to_string(VkImageLayout layout)
    {
        switch (layout)
        {
            VK_ENUM_CONVERT_TO_STRING_CASE(VK_IMAGE_LAYOUT_UNDEFINED);
            VK_ENUM_CONVERT_TO_STRING_CASE(VK_IMAGE_LAYOUT_GENERAL);
