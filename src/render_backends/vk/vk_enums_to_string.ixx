            VK_ENUM_CONVERT_TO_STRING_CASE(VK_IMAGE_LAYOUT_PREINITIALIZED);
            VK_ENUM_CONVERT_TO_STRING_CASE(VK_IMAGE_LAYOUT_DEPTH_READ_ONLY_STENCIL_ATTACHMENT_OPTIMAL);
