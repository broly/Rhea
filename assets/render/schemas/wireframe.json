{
    "model_name": "wireframe",

    "usage_type": "frame",

    "ubo_access": "none",

    "parameters": {
    },

    "passes": [
        {
			"set": "SET_WIREFRAME",
            "name": "wireframe",
            "shaders": {
                "vertex": "wireframe.vert",
                "fragment": "wireframe.frag"
            },
			"resources": ["camera"],

            "depth_test": true,
            "depth_write": false,
            "translucent": false,
            "cull_mode": "none",
            "front_face": "CW",
			"compare_op": "less_or_equal",
			"push_constants": [],
			"topology": "line_list",
			"vertex_layouts": [
				{
					"vertex_type": "LineVertex",
					"attributes": [ 
						{ 
							"name": "position",
							"definition": "LOCATION_ATTR_POSITION",
							"variable": "in_position"
						},
						{
							"name": "color",
							"definition": "LOCATION_ATTR_COLOR",
							"variable": "in_color"
						}
					]
				}
			]
        }
    ]
}
