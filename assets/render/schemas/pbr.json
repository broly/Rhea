{
	"model_name": "PBR",
	
	"enums": {
		"blend_mode": [
			"opaque",
			"masked",
			"translucent"
		]
	},
	
	"uniform_buffers": {
		"material": {
			"type_name": "MaterialUBO",
			"binding": 0
		}
	},
	
	"sampler": "surface",
	
	"parameters": {
		"blend_mode": {
			"type": "blend_mode",
			"dynamic": false,
			"shader_parameter": null,
			"ubo": null,
			"binding": null
		},
		"base_color": {
			"type": "sampler",
			"dynamic": true,
			"shader_parameter": "u_base_color",
			"ubo": null,
			"binding": 1
		},
		"emissive": {
			"type": "sampler",
			"dynamic": true,
			"shader_parameter": "u_emissive",
			"ubo": null,
			"binding": 2
		},
		"normal": {
			"type": "sampler",
			"dynamic": true,
			"shader_parameter": "u_normal_map",
			"ubo": null,
			"binding": 3
		},
		"orm": {
			"type": "sampler",
			"dynamic": true,
			"shader_parameter": "u_orm",
			"ubo": null,
			"binding": 4
		},
		"base_color_factor": {
			"type": "vec4",
			"dynamic": true,
			"shader_parameter": null,
			"ubo": "material",
			"binding": null
		},
		"emissive_factor": {
			"type": "vec4",
			"dynamic": true,
			"shader_parameter": null,
			"ubo": "material",
			"binding": null
		},
		"occlusion_factor": {
			"type": "vec4",
			"dynamic": true,
			"shader_parameter": null,
			"ubo": "material",
			"binding": null
		},
		"metallic_factor": {
			"type": "vec4",
			"dynamic": true,
			"shader_parameter": null,
			"ubo": "material",
			"binding": null
		},
		"roughness_factor": {
			"type": "vec4",
			"dynamic": true,
			"shader_parameter": null,
			"ubo": "material",
			"binding": null
		}
	},	
	"permutations": {
		"flags": {
			"USE_BASE_COLOR": "base_color || base_color_factor",
			"USE_NORMAL_MAP": "normal",
			"USE_ORM": "orm || metallic_factor || roughness_factor"
		},
		"enums": {
			"blend_mode": {
				"opaque": "BLEND_MODE_OPAQUE",
				"masked": "BLEND_MODE_MASKED",
				"translucent": "BLEND_MODE_TRANSLUCENT",
			}
		}
	},
	"set": 3,
	"passes": [	
		{
			"name": "GeometryBase",
			"requirements": "blend_mode != translucent",
			"enum_white_list": {
				"blend_mode": ["opaque", "masked"]
			},
			"shaders": {
				"vertex": "geometry.vert",
				"fragment": "geometry.frag"
			}
		},
		{
			"name": "GeometryTranslucent",
			"requirements": "blend_mode == translucent",
			"enum_white_list": {
				"blend_mode": ["translucent"]
			},
			"shaders": {
				"vertex": "geometry.vert",
				"fragment": "geometry.frag"
			}
		}
	]
}