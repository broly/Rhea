				}
			]
		},
		{
			"__type__": "PipelineInfo_Graphics",
			"pass": "GeometryTranslucent",
			"requirements": "blend_mode == translucent",
			"stages": {
				"vertex": {
					"shader": "geometry.vert",
					"resources": ["camera", "mesh_table", "primitive_table"]
				},
				"fragment": {
					"shader": "geometry.frag",
					"resources": ["camera", "light", "shadow", "reflection", "pbr_material_table", "textures"]
				}
			},
			"depth_write": false,
			"depth_test": true,
			"cull_mode": "back",
			"front_face": "CW",
			"compare_op": "less_or_equal",
