{
	"model_name": "PBR",
	
	"usage_type": "persistent",
	
	"enums": {
		"blend_mode": [
			"opaque",
			"masked",
			"translucent"
		]
	},
	
	"sampler": "surface",
	
	"parameters": {
		"blend_mode": {
			"type": "definition",
			"definition": "blend_mode"
		},
		"base_color": {
			"type": "sampler",
			"variable": "u_base_color",
			"binding": "BINDING_SAMPLER_ALBEDO",
			"passes": ["GeometryBase", "GeometryTranslucent"]
		},
		"emissive": {
			"type": "sampler",
			"variable": "u_emissive",
			"binding": "BINDING_SAMPLER_EMISSIVE",
			"passes": ["GeometryBase", "GeometryTranslucent"]
		},
		"normal": {
			"type": "sampler",
			"variable": "u_normal_map",
			"binding": "BINDING_SAMPLER_NORMAL",
			"passes": ["GeometryBase", "GeometryTranslucent"]
		},
		"orm": {
			"type": "sampler",
			"variable": "u_orm",
			"binding": "BINDING_SAMPLER_ORM",
			"passes": ["GeometryBase", "GeometryTranslucent"]
		},
		"material": {
			"type": "uniform",
			"ubo": "MaterialUBO",
			"binding": "BINDING_MATERIAL",
			"variable": "material_ubo",
			"passes": ["GeometryBase", "GeometryTranslucent"]
		},
		"base_color_factor": {
			"type": "vec4",
			"storage": "material"
		},
		"emissive_factor": {
			"type": "vec4",
			"storage": "material"
		},
		"occlusion_factor": {
			"type": "vec4",
			"storage": "material"
		},
		"metallic_factor": {
			"type": "vec4",
			"storage": "material"
		},
		"roughness_factor": {
			"type": "vec4",
			"storage": "material"
		}
	},	
	"permutations": {
		"flags": {
			"USE_BASE_COLOR": "base_color",
			"USE_NORMAL_MAP": "normal",
			"USE_ORM": "orm"
		},
		"enums": {
			"blend_mode": {
				"opaque": "BLEND_MODE_OPAQUE",
				"masked": "BLEND_MODE_MASKED",
				"translucent": "BLEND_MODE_TRANSLUCENT"
			}
		}
	},

	
	"passes": [	
		{
			"name": "GeometryBase",
			"requirements": "blend_mode != translucent",
			"shaders": {
				"vertex": "geometry.vert",
				"fragment": "geometry.frag"
			},
			"depth_write": true,
			"depth_test": true,
			"set": "SET_PBR",
	
			"resources": ["camera", "light", "shadow", "reflection"],
			"translucent": false,
			"cull_mode": "back",
			"front_face": "CW",
			"compare_op": "less",
			"push_constants": [
				{
					"type": "mat4",
					"name": "camera",
					"stages": ["vertex"]
				}
			],
			"vertex_layouts": [
				{
					"vertex_type": "Vertex",
					"attributes": [ 
						{ 
							"name": "position",
							"definition": "LOCATION_ATTR_POSITION",
							"variable": "in_position"
						},
						{
							"name": "normal",
							"definition": "LOCATION_ATTR_NORMAL",
							"variable": "in_normal"
						},
						{
							"name": "tex_coord",
							"definition": "LOCATION_ATTR_UV",
							"variable": "in_uv"
						},
						{
							"name": "tangent",
							"definition": "LOCATION_ATTR_TANGENT",
							"variable": "in_tangent"
						}
					]
				}
			]
		},
		{
			"name": "GeometryTranslucent",
			"requirements": "blend_mode == translucent",
			"shaders": {
				"vertex": "geometry.vert",
				"fragment": "geometry.frag"
			},
			"resources": ["camera", "light", "shadow", "reflection"],
			"depth_write": false,
			"depth_test": true,
			"translucent": true,
			"cull_mode": "back",
			"front_face": "CW",
			"compare_op": "less",
			"set": "SET_PBR",
			"push_constants": [
				{
					"type": "mat4",
					"name": "camera",
					"stages": ["vertex"]
				}
			],
			"vertex_layouts": [
				{
					"vertex_type": "Vertex",
					"attributes": [ 
						{ 
							"name": "position",
							"definition": "LOCATION_ATTR_POSITION",
							"variable": "in_position"
						},
						{
							"name": "normal",
							"definition": "LOCATION_ATTR_NORMAL",
							"variable": "in_normal"
						},
						{
							"name": "tex_coord",
							"definition": "LOCATION_ATTR_UV",
							"variable": "in_uv"
						},
						{
							"name": "tangent",
							"definition": "LOCATION_ATTR_TANGENT",
							"variable": "in_tangent"
						}
					]
				}
			]
		},
		{
			"name": "shadowmap",
			"requirements": "blend_mode != translucent",
			"shaders": {
				"vertex": "shadow.vert",
				"fragment": "shadow.frag"
			},
			"resources": ["shadow_light"],
			"depth_write": true,
			"depth_test": true,
			"translucent": false,
			"cull_mode": "none",
			"front_face": "CCW",
			"compare_op": "less",
			"push_constants": [
				{
					"type": "mat4",
					"name": "camera",
					"stages": ["vertex"]
				}
			],
			"set": "SET_SHADOW",
			"depth_bias": {
				"enable": true,
				"constant_factor": 0.1,
				"slope_factor": 1.0,
				"clamp": 0
			},
			"vertex_layouts": [
				{
					"vertex_type": "Vertex",
					"attributes": [ 
						{ 
							"name": "position",
							"definition": "LOCATION_ATTR_POSITION",
							"variable": "in_position"
						},
					]
				}
			],
		}
	]
}