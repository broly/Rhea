{
	"name": "PBR",
	
	"enums": {
		"blend_mode": [
			"opaque",
			"masked",
			"translucent"
		]
	},
	
	"uniform_buffers": {
		"material": "MaterialUBO"
	},
	
	"parameters": {
		"blend_mode": {
			"type": "blend_mode",
			"shader_parameter": null
		},
		"base_color": {
			"type": "sampler",
			"shader_parameter": "u_base_color",
			"ubo": null
		},
		"emissive": {
			"type": "sampler",
			"shader_parameter": "u_emissive",
			"ubo": null
		},
		"normal": {
			"type": "sampler",
			"shader_parameter": "u_normal_map",
			"ubo": null
		},
		"orm": {
			"type": "sampler",
			"shader_parameter": "u_orm",
			"ubo": null
		},
		"base_color_factor": {
			"type": "vec4",
			"shader_parameter": null,
			"ubo": "material"
		},
		"emissive_factor": {
			"type": "vec4",
			"shader_parameter": null,
			"ubo": "material"
		},
		"occlusion_factor": {
			"type": "vec4",
			"shader_parameter": null,
			"ubo": "material"
		},
		"metallic_factor": {
			"type": "vec4",
			"shader_parameter": null,
			"ubo": "material"
		},
		"roughness_factor": {
			"type": "vec4",
			"shader_parameter": null,
			"ubo": "material"
		}
	},
	"permutations": {
		"flags": {
			"USE_BASE_COLOR": "base_color || base_color_factor",
			"USE_NORMAL_MAP": "normal",
			"USE_ORM": "orm || metallic_factor || roughness_factor"
		},
		"enums": {
			"blend_mode": {
				"opaque": "BLEND_MODE_OPAQUE",
				"masked": "BLEND_MODE_MASKED",
				"translucent": "BLEND_MODE_TRANSLUCENT",
			}
		}
	},
	"passes": [	
		{
			"name": "GeometryBase",
			"requirements": "blend_mode != translucent",
			"shaders": {
				"vertex": "geometry.vert",
				"fragment": "geometry.frag"
			}
		},
		{
			"name": "GeometryTranslucent",
			"requirements": "blend_mode == translucent",
			"shaders": {
				"vertex": "geometry.vert",
				"fragment": "geometry.frag"
			}
		}
	]
}