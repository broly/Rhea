					"resources": ["camera", "light", "shadow", "reflection", "pbr_material_table", "textures"]
				}
			},
			"depth_write": true,
			"depth_test": true,
			
			"color_attachments": [
				{
					"write_mask": ["R", "G", "B", "A"],
					"translucent": false
