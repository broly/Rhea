{
	"model_name": "PBR",
	
	"material_resource": "pbr_material",
	
	"enums": {
		"blend_mode": [
			"opaque",
			"masked",
			"translucent"
		]
	},
	
	"permutations": {
		"flags": {
			"USE_BASE_COLOR": "base_color",
			"USE_NORMAL_MAP": "normal",
			"USE_ORM": "orm"
		},
		"enums": {
			"blend_mode": {
				"opaque": "BLEND_MODE_OPAQUE",
				"masked": "BLEND_MODE_MASKED",
				"translucent": "BLEND_MODE_TRANSLUCENT"
			}
		}
	},

	
	"pipelines": [
		{
			"__type__": "PipelineInfo_Graphics",
			"pass": "GeometryBase",
			"requirements": "blend_mode != translucent",
			"stages": {
				"vertex": {
					"shader": "geometry.vert",
					"resources": ["camera"]
				},
				"fragment": {
					"shader": "geometry.frag",
					"resources": ["camera", "light", "shadow", "reflection", "pbr_material"]
				}
			},
			"depth_write": true,
			"depth_test": true,
			
			"color_attachments": [
				{
					"write_mask": ["R", "G", "B", "A"],
					"translucent": false
				},
				{
					"write_mask": ["R", "G", "B", "A"],
					"translucent": false
				},
				{
					"write_mask": ["R", "G"],
					"translucent": false
				},
				{
					"write_mask": ["R"],
					"translucent": false
				}
			],
	
			"cull_mode": "back",
			"front_face": "CW",
			"compare_op": "less_or_equal",
			"push_constants": [
				{
					"type": "ModelPushConstants",
					"name": "model",
					"stages": ["vertex"]
				}
			],
			"topology": "triangle_list",
			"vertex_layouts": [
				{
					"vertex_type": "Vertex",
					"attributes": [ 
						{ 
							"name": "position",
							"definition": "LOCATION_ATTR_POSITION",
							"variable": "in_position"
						},
						{
							"name": "normal",
							"definition": "LOCATION_ATTR_NORMAL",
							"variable": "in_normal"
						},
						{
							"name": "tex_coord",
							"definition": "LOCATION_ATTR_UV",
							"variable": "in_uv"
						},
						{
							"name": "tangent",
							"definition": "LOCATION_ATTR_TANGENT",
							"variable": "in_tangent"
						}
					]
				}
			]
		},
		{
			"__type__": "PipelineInfo_Graphics",
			"pass": "GeometryTranslucent",
			"requirements": "blend_mode == translucent",
			"stages": {
				"vertex": {
					"shader": "geometry.vert",
					"resources": ["camera"]
				},
				"fragment": {
					"shader": "geometry.frag",
					"resources": ["camera", "light", "shadow", "reflection", "pbr_material"]
				}
			},
			"depth_write": false,
			"depth_test": true,
			"cull_mode": "back",
			"front_face": "CW",
			"compare_op": "less_or_equal",
			"set": "SET_PBR",
			"color_attachments": [
				{
					"write_mask": ["R", "G", "B", "A"],
					"translucent": true
				}
			],
			"push_constants": [
				{
					"type": "ModelPushConstants",
					"name": "model",
					"stages": ["vertex"]
				}
			],
			"topology": "triangle_list",
			"vertex_layouts": [
				{
					"vertex_type": "Vertex",
					"attributes": [ 
						{ 
							"name": "position",
							"definition": "LOCATION_ATTR_POSITION",
							"variable": "in_position"
						},
						{
							"name": "normal",
							"definition": "LOCATION_ATTR_NORMAL",
							"variable": "in_normal"
						},
						{
							"name": "tex_coord",
							"definition": "LOCATION_ATTR_UV",
							"variable": "in_uv"
						},
						{
							"name": "tangent",
							"definition": "LOCATION_ATTR_TANGENT",
							"variable": "in_tangent"
						}
					]
				}
			]
		},
		{
			"__type__": "PipelineInfo_Graphics",
			"pass": "shadowmap",
			"requirements": "blend_mode != translucent",
			"stages": {
				"vertex": {
					"shader": "shadow.vert",
					"resources": ["camera", "light"]
				},
				"fragment": {
					"shader": "shadow.frag",
					"resources": []
				}
			},
			"depth_write": true,
			"depth_test": true,
			"translucent": false,
			"cull_mode": "none",
			"front_face": "CCW",
			"compare_op": "less",
			"color_attachments": [
				{
					"write_mask": ["R", "G", "B", "A"],
					"translucent": false
				}
			],
			"push_constants": [
				{
					"type": "ModelPushConstants",
					"name": "model",
					"stages": ["vertex"]
				}
			],
			"set": "SET_SHADOW",
			"depth_bias": {
				"enable": true,
				"constant_factor": 0.1,
				"slope_factor": 1.0,
				"clamp": 0
			},
			"topology": "triangle_list",
			"vertex_layouts": [
				{
					"vertex_type": "Vertex",
					"attributes": [ 
						{ 
							"name": "position",
							"definition": "LOCATION_ATTR_POSITION",
							"variable": "in_position"
						},
					]
				}
			],
		}
	]
}