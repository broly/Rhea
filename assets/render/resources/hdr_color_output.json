				"array_size_definition": "NUM_HDR_COLOR_ARRAY_ELEMENTS"
			},
			"history": {
				"type": "sampler",
				"sampler": "default",
				"variable": "u_history",
				"binding": "BINDING_SAMPLER_HISTORY",
				"initial_array_size": 9,
				"array_size_definition": "NUM_HISTORY_ARRAY_ELEMENTS"
			}
		}
	}
}