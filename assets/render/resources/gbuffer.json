{
	"resource": {
		"name": "gbuffer",
		"usage": "frame",
		"set": "SET_GBUFFER",
		"allowed_stages": ["fragment", "rtx_raygen", "compute"],
		"parameters": {
			"gbuffer": {
				"type": "sampler",
				"sampler": "default",
				"variable": "u_gbuffer",
				"binding": "BINDING_SAMPLER_ARRAY_GBUFFER",
				"initial_array_size": 8,
				"array_size_definition": "NUM_GBUFFER_SLOTS"
			},
			"gbuffer_hist": {
				"type": "sampler",
				"sampler": "default",
				"variable": "u_gbuffer_hist",
				"binding": "BINDING_SAMPLER_ARRAY_GBUFFER_HIST",
				"initial_array_size": 8
			}
		}
	}
}