		"allowed_stages": ["fragment", "rtx_raygen"],
		"parameters": {
			"depth": {
				"type": "sampler",
				"sampler": "default",
				"variable": "u_depth",
				"binding": "BINDING_SAMPLER_DEPTH"
			},
			"normal": {
				"type": "sampler",
				"sampler": "default",
				"variable": "u_normal",
				"binding": "BINDING_SAMPLER_NORMAL"
			},
			"world_normal": {
				"type": "sampler",
				"sampler": "default",
				"variable": "u_world_normal",
				"binding": "BINDING_SAMPLER_WORLD_NORMAL"
			},
			"roughness": {
				"type": "sampler",
				"sampler": "default",
				"variable": "u_roughness",
				"binding": "BINDING_SAMPLER_ROUGHNESS"
			},
			"albedo": {
				"type": "sampler",
				"sampler": "default",
				"variable": "u_albedo",
				"binding": "BINDING_SAMPLER_ALBEDO"
			},
			"position": {
				"type": "sampler",
				"sampler": "default",
				"variable": "u_position",
				"binding": "BINDING_SAMPLER_POSITION"
			},
			"shadow": {
				"type": "sampler",
				"sampler": "default",
				"variable": "u_shadow",
				"binding": "BINDING_SAMPLER_POSITION"
			}
