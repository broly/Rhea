{
  "resource": {
    "name": "textures",
    "usage": "persistent",
    "set": "SET_TEXTURES",
    "allowed_stages": ["fragment", "rtx_raygen", "rtx_any_hit", "rtx_closest_hit", "rtx_miss", "rtx_intersection"],
    "parameters": {
      "textures": {
        "type": "sampler",
        "sampler": "default",
        "variable": "u_textures_array",
        "binding": "BINDING_ARRAY_TEXTURES",
        "initial_array_size": 2048
      }
    }
  }
}