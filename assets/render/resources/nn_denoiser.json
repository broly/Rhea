{
    "resource": {
        "name": "nn_denoiser",
        "usage": "persistent",
        "set": "SET_NN_DENOISER",
        "allowed_stages": ["compute", "fragment"],
        "parameters": {
            "pass_indices": {
                "type": "ssbo",
                "variable": "u_nn_pass_indices",
                "binding": "BINDING_NN_PASS_INDICES",
                "initial_buffer_size": 32000
            },

            "activations": {
                "type": "image",
                "variable": "u_nn_activations",
                "binding": "BINDING_NN_ACTIVATIONS",
                "initial_array_size": 1024,
                "array_size_definition": "NN_NUM_ACTIVATION_SLOTS"
            },

            "pw_weights": {
                "type": "ssbo",
                "variable": "u_nn_pw_weights",
                "binding": "BINDING_NN_PW_WEIGHTS",
                "initial_buffer_size": 624512
            },
            "dw_weights": {
                "type": "ssbo",
                "variable": "u_nn_dw_weights",
                "binding": "BINDING_NN_DW_WEIGHTS",
                "initial_buffer_size": 45360
            },
            "biases": {
                "type": "ssbo",
                "variable": "u_nn_biases",
                "binding": "BINDING_NN_BIASES",
                "initial_buffer_size": 5520
            },
            "weight_layout": {
                "type": "ssbo",
                "variable": "u_nn_weight_layout",
                "binding": "BINDING_NN_WEIGHT_LAYOUT",
                "initial_buffer_size": 800
            }
        }
    }
}
