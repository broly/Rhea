#version 450

#include "resources/gbuffer.glsl"
#include "resources/hdr_color_output.glsl"
#include "resources/hdr_color_storage.glsl"

layout(local_size_x = 8, local_size_y = 8) in;

layout(push_constant) uniform PushRTXGIValidate
{
    vec2 resolution;
    float position_threshold; 
    float normal_threshold;
} pc;

void main()
{
    ivec2 px = ivec2(gl_GlobalInvocationID.xy);

    vec2 uv = (vec2(px) + 0.5) / pc.resolution;

    // motion vectors
    vec2 motion = get_gbuffer_MOTION_VECTORS(uv).xy;

    vec2 prevUV = uv + motion / pc.resolution;

    if (any(lessThan(prevUV, vec2(0.0))) || any(greaterThan(prevUV, vec2(1.0))))
    {
        imageStore(u_hdr_color_present_storage[COLOR_OUTPUT_HDR_RTXGI_REPROJECTED], px, vec4(0.0));
        return;
    }

    // history color
    vec3 history = texture(u_hdr_color_history[COLOR_OUTPUT_HDR_RTXGI], prevUV).rgb;

    // --- WORLD POSITION ---
    vec3 P  = get_gbuffer_POSITION(uv).xyz;
    vec3 Pp = get_gbuffer_hist_POSITION(prevUV).xyz;

    float positionDiff = length(P - Pp);

    // --- NORMAL ---
    vec3 n  = normalize(get_gbuffer_WORLD_NORMAL(uv).xyz * 2.0 - 1.0);
    vec3 pn = normalize(get_gbuffer_hist_WORLD_NORMAL(prevUV).xyz * 2.0 - 1.0);

    float normalDot = dot(n, pn);

    // --- VALIDATION ---
    bool valid = (positionDiff < pc.position_threshold) && (normalDot > pc.normal_threshold);

    imageStore(
        u_hdr_color_present_storage[COLOR_OUTPUT_HDR_RTXGI_REPROJECTED],
        px,
        vec4(history, valid ? 1.0 : 0.0)
    );
}